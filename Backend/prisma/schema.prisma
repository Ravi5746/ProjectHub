generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id                   Int        @id @default(autoincrement()) @db.UnsignedInt
  name                 String     @db.VarChar(255)
  email                String     @unique @db.VarChar(255)
  password             String     @db.VarChar(255)
  avatar               String?    @db.VarChar(500)
  mobile               String?    @db.VarChar(20)
  role                 UserRole   @default(MEMBER)
  status               UserStatus @default(UNVERIFIED)
  refreshToken         String?    @map("refresh_token") @db.Text
  verifyEmailToken     String?    @map("verify_email_token") @db.Text
  verifyEmailOtp       String?    @map("verify_email_otp") @db.VarChar(10)
  verifyEmailExpiry    DateTime?  @map("verify_email_expiry")
  forgotPasswordOtp    String?    @map("forgot_password_otp") @db.VarChar(10)
  forgotPasswordExpiry DateTime?  @map("forgot_password_expiry")
  lastLoginDate        DateTime?  @map("last_login_date")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  deletedAt            DateTime?  @map("deleted_at")

  projectsCreated      Project[]       @relation("ProjectCreator")
  tasksCreated         Task[]          @relation("TaskCreator")
  tasksAssigned        Task[]          @relation("TaskAssignee")
  projectMembers       ProjectMember[]
  activityLogs         ActivityLog[]

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Project {
  id          Int           @id @default(autoincrement()) @db.UnsignedInt
  name        String        @db.VarChar(255)
  description String?       @db.Text
  status      ProjectStatus @default(ACTIVE)
  createdBy   Int           @map("created_by") @db.UnsignedInt
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  creator       User            @relation("ProjectCreator", fields: [createdBy], references: [id])
  members       ProjectMember[]
  tasks         Task[]
  activityLogs  ActivityLog[]

  @@index([createdBy])
  @@index([deletedAt])
  @@map("projects")
}

model ProjectMember {
  id        Int        @id @default(autoincrement()) @db.UnsignedInt
  projectId Int        @map("project_id") @db.UnsignedInt
  userId    Int        @map("user_id") @db.UnsignedInt
  role      MemberRole @default(MEMBER)
  joinedAt  DateTime   @default(now()) @map("joined_at")

  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model Task {
  id          Int          @id @default(autoincrement()) @db.UnsignedInt
  projectId   Int          @map("project_id") @db.UnsignedInt
  title       String       @db.VarChar(255)
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  deadline    DateTime?    @db.Date
  assigneeId  Int?         @map("assignee_id") @db.UnsignedInt
  createdBy   Int          @map("created_by") @db.UnsignedInt
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  project   Project @relation(fields: [projectId], references: [id])
  creator   User    @relation("TaskCreator", fields: [createdBy], references: [id])
  assignee  User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([deadline])
  @@index([deletedAt])
  @@index([createdBy], map: "tasks_created_by_fkey")
  @@map("tasks")
}

model ActivityLog {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  projectId  Int      @map("project_id") @db.UnsignedInt
  userId     Int      @map("user_id") @db.UnsignedInt
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   Int?     @map("entity_id") @db.UnsignedInt
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

enum UserRole {
  SUPER_ADMIN
  PROJECT_ADMIN
  MEMBER
}

enum UserStatus {
  UNVERIFIED
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum MemberRole {
  PROJECT_ADMIN
  MEMBER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
